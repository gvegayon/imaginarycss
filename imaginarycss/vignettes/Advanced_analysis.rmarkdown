# Create density effect plots using the correlation results we have
plot_density_effects <- function(density_data, network_name) {
  
  # Extract the data we have
  accuracy_data <- density_data$accuracy
  standardized_density <- density_data$standardized_density
  
  # Create plot data
  plot_data <- data.frame(
    standardized_density = standardized_density,
    p_1_ego = accuracy_data$p_1_ego,
    p_0_ego = accuracy_data$p_0_ego,
    p_1_alter = accuracy_data$p_1_alter,
    p_0_alter = accuracy_data$p_0_alter,
    individual = 1:length(standardized_density)
  )
  
  # Remove any rows with missing data
  plot_data <- plot_data[complete.cases(plot_data), ]
  
  cat("Creating plots for", network_name, "with", nrow(plot_data), "individuals\n")
  
  library(ggplot2)
  
  # Plot 1: Standardized density vs True Positive Rate (Ego)
  p1 <- ggplot(plot_data, aes(x = standardized_density, y = p_1_ego)) +
    geom_point(alpha = 0.7, size = 3, color = "blue") +
    geom_smooth(method = "lm", se = TRUE, color = "darkblue") +
    labs(title = paste(network_name, "Network: Density vs True Positive Rate (Ego)"),
         subtitle = paste("Correlation:", round(cor(plot_data$standardized_density, plot_data$p_1_ego), 3)),
         x = "Standardized Perceived Density", 
         y = "P(1|1) Ego - True Positive Rate") +
    theme_minimal() +
    theme(plot.title = element_text(size = 12, face = "bold"))
  
  # Plot 2: Standardized density vs True Negative Rate (Ego)
  p2 <- ggplot(plot_data, aes(x = standardized_density, y = p_0_ego)) +
    geom_point(alpha = 0.7, size = 3, color = "red") +
    geom_smooth(method = "lm", se = TRUE, color = "darkred") +
    labs(title = paste(network_name, "Network: Density vs True Negative Rate (Ego)"),
         subtitle = paste("Correlation:", round(cor(plot_data$standardized_density, plot_data$p_0_ego), 3)),
         x = "Standardized Perceived Density", 
         y = "P(0|0) Ego - True Negative Rate") +
    theme_minimal() +
    theme(plot.title = element_text(size = 12, face = "bold"))
  
  # Plot 3: Standardized density vs True Positive Rate (Alter)
  p3 <- ggplot(plot_data, aes(x = standardized_density, y = p_1_alter)) +
    geom_point(alpha = 0.7, size = 3, color = "green") +
    geom_smooth(method = "lm", se = TRUE, color = "darkgreen") +
    labs(title = paste(network_name, "Network: Density vs True Positive Rate (Alter)"),
         subtitle = paste("Correlation:", round(cor(plot_data$standardized_density, plot_data$p_1_alter), 3)),
         x = "Standardized Perceived Density", 
         y = "P(1|1) Alter - True Positive Rate") +
    theme_minimal() +
    theme(plot.title = element_text(size = 12, face = "bold"))
  
  # Plot 4: Standardized density vs True Negative Rate (Alter)
  p4 <- ggplot(plot_data, aes(x = standardized_density, y = p_0_alter)) +
    geom_point(alpha = 0.7, size = 3, color = "purple") +
    geom_smooth(method = "lm", se = TRUE, color = "purple4") +
    labs(title = paste(network_name, "Network: Density vs True Negative Rate (Alter)"),
         subtitle = paste("Correlation:", round(cor(plot_data$standardized_density, plot_data$p_0_alter), 3)),
         x = "Standardized Perceived Density", 
         y = "P(0|0) Alter - True Negative Rate") +
    theme_minimal() +
    theme(plot.title = element_text(size = 12, face = "bold"))
  
  # Print the plots
  print(p1)
  print(p2)
  print(p3)
  print(p4)
  
  # Calculate and report all correlations
  correlations <- c(
    p1_ego = cor(plot_data$standardized_density, plot_data$p_1_ego),
    p0_ego = cor(plot_data$standardized_density, plot_data$p_0_ego),
    p1_alter = cor(plot_data$standardized_density, plot_data$p_1_alter),
    p0_alter = cor(plot_data$standardized_density, plot_data$p_0_alter)
  )
  
  cat("\n", network_name, "Network Density-Accuracy Correlations:\n")
  cat("Standardized Density vs P(1|1) Ego:", round(correlations[1], 3), "\n")
  cat("Standardized Density vs P(0|0) Ego:", round(correlations[2], 3), "\n")
  cat("Standardized Density vs P(1|1) Alter:", round(correlations[3], 3), "\n")
  cat("Standardized Density vs P(0|0) Alter:", round(correlations[4], 3), "\n\n")
  
  return(list(
    plot1 = p1, plot2 = p2, plot3 = p3, plot4 = p4, 
    correlations = correlations,
    data = plot_data
  ))
}

# Create the density plots for both networks
cat("=== CREATING DENSITY EFFECT PLOTS ===\n")

friendship_density_plots <- plot_density_effects(friendship_density, "Friendship")
advice_density_plots <- plot_density_effects(advice_density, "Advice")

# Summary plot comparing both networks
create_comparison_plot <- function(friendship_data, advice_data) {
  
  # Combine data for comparison
  combined_data <- rbind(
    data.frame(friendship_data$data, Network = "Friendship"),
    data.frame(advice_data$data, Network = "Advice")
  )
  
  # Faceted comparison plot
  comparison_plot <- ggplot(combined_data, aes(x = standardized_density, y = p_1_ego, color = Network)) +
    geom_point(alpha = 0.7, size = 2) +
    geom_smooth(method = "lm", se = TRUE) +
    facet_wrap(~Network, scales = "free") +
    labs(title = "Density Effects Comparison: Friendship vs Advice Networks",
         subtitle = "Relationship between perceived density and true positive rates",
         x = "Standardized Perceived Density", 
         y = "P(1|1) Ego - True Positive Rate") +
    theme_minimal() +
    theme(legend.position = "bottom") +
    scale_color_manual(values = c("Friendship" = "blue", "Advice" = "red"))
  
  print(comparison_plot)
  
  return(comparison_plot)
}

# Create comparison plot
comparison_plot <- create_comparison_plot(friendship_density_plots, advice_density_plots)

