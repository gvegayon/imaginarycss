# Create a simple accuracy visualization
create_accuracy_plot <- function(friendship_data, advice_data) {
  library(ggplot2)
  
  combined_data <- rbind(
    data.frame(Individual = friendship_data$k, 
               Accuracy = friendship_data$overall_accuracy,
               Network = "Friendship"),
    data.frame(Individual = advice_data$k,
               Accuracy = advice_data$overall_accuracy, 
               Network = "Advice")
  )
  
  p <- ggplot(combined_data, aes(x = factor(Individual), y = Accuracy, fill = Network)) +
    geom_col(position = "dodge", alpha = 0.7) +
    geom_hline(yintercept = 0.75, linetype = "dashed", color = "green", alpha = 0.7) +
    geom_hline(yintercept = 0.5, linetype = "dashed", color = "red", alpha = 0.7) +
    labs(title = "Individual Network Perception Accuracy",
         subtitle = "Green line = Good performance, Red line = Needs improvement",
         x = "Individual ID", y = "Overall Accuracy") +
    theme_minimal() +
    theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
    scale_fill_manual(values = c("Friendship" = "lightblue", "Advice" = "lightcoral"))
  
  print(p)
  return(p)
}

# Create the visualization
accuracy_plot <- create_accuracy_plot(friendship_individual, advice_individual)

