# Add overall accuracy calculation
add_overall_accuracy <- function(accuracy_data) {
  if(!"overall_accuracy" %in% names(accuracy_data)) {
    accuracy_data$overall_accuracy <- rowMeans(
      accuracy_data[, c("p_1_ego", "p_0_ego", "p_1_alter", "p_0_alter")], 
      na.rm = TRUE
    )
  }
  return(accuracy_data)
}

