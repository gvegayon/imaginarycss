# Updated training identification with appropriate thresholds
identify_training_candidates_fixed <- function(accuracy_data, network_name, method = "quartile") {
  
  if(method == "quartile") {
    # Use bottom 25% as training candidates
    threshold <- quantile(accuracy_data$overall_accuracy, 0.25, na.rm = TRUE)
    low_accuracy <- accuracy_data$k[accuracy_data$overall_accuracy <= threshold]
  } else {
    # Use fixed threshold but adjust based on data
    threshold <- max(0.6, median(accuracy_data$overall_accuracy, na.rm = TRUE) - 0.1)
    low_accuracy <- accuracy_data$k[accuracy_data$overall_accuracy < threshold]
  }
  
  cat("=== TRAINING ANALYSIS:", toupper(network_name), "NETWORK ===\n")
  cat("Threshold used:", round(threshold, 3), "\n")
  cat("Individuals recommended for network perception training:\n")
  
  if(length(low_accuracy) > 0) {
    cat("IDs:", paste(low_accuracy, collapse = ", "), "\n")
    cat("Current accuracy:", round(accuracy_data$overall_accuracy[accuracy_data$k %in% low_accuracy], 3), "\n")
    cat("Number needing training:", length(low_accuracy), "out of", nrow(accuracy_data), "\n")
  } else {
    cat("No individuals below threshold\n")
    # Show lowest performers anyway
    lowest_performers <- accuracy_data$k[order(accuracy_data$overall_accuracy)[1:3]]
    cat("Lowest 3 performers:", paste(lowest_performers, collapse = ", "), "\n")
    cat("Their accuracy:", round(accuracy_data$overall_accuracy[accuracy_data$k %in% lowest_performers], 3), "\n")
    low_accuracy <- lowest_performers
  }
  cat("\n")
  
  return(low_accuracy)
}

# Run the fixed training identification
friendship_training <- identify_training_candidates_fixed(friendship_individual, "Friendship")
advice_training <- identify_training_candidates_fixed(advice_individual, "Advice")

# Detailed performance breakdown
performance_breakdown <- function(accuracy_data, network_name) {
  
  cat("=== DETAILED PERFORMANCE BREAKDOWN:", toupper(network_name), "===\n")
  
  # Performance tiers
  high_perf <- accuracy_data$overall_accuracy > quantile(accuracy_data$overall_accuracy, 0.75, na.rm = TRUE)
  avg_perf <- accuracy_data$overall_accuracy >= quantile(accuracy_data$overall_accuracy, 0.25, na.rm = TRUE) & 
    accuracy_data$overall_accuracy <= quantile(accuracy_data$overall_accuracy, 0.75, na.rm = TRUE)
  low_perf <- accuracy_data$overall_accuracy < quantile(accuracy_data$overall_accuracy, 0.25, na.rm = TRUE)
  
  cat("HIGH PERFORMERS (top 25%):", sum(high_perf), "individuals\n")
  cat("  Average accuracy:", round(mean(accuracy_data$overall_accuracy[high_perf], na.rm = TRUE), 3), "\n")
  cat("  IDs:", paste(accuracy_data$k[high_perf], collapse = ", "), "\n\n")
  
  cat("AVERAGE PERFORMERS (middle 50%):", sum(avg_perf), "individuals\n") 
  cat("  Average accuracy:", round(mean(accuracy_data$overall_accuracy[avg_perf], na.rm = TRUE), 3), "\n")
  cat("  IDs:", paste(accuracy_data$k[avg_perf], collapse = ", "), "\n\n")
  
  cat("LOW PERFORMERS (bottom 25%):", sum(low_perf), "individuals\n")
  cat("  Average accuracy:", round(mean(accuracy_data$overall_accuracy[low_perf], na.rm = TRUE), 3), "\n")
  cat("  IDs:", paste(accuracy_data$k[low_perf], collapse = ", "), "\n\n")
  
  # Skill-specific issues
  cat("SKILL-SPECIFIC TRAINING NEEDS:\n")
  cat("Poor ego accuracy (P(1|1) + P(0|0) < median):\n")
  
  ego_accuracy <- rowMeans(accuracy_data[, c("p_1_ego", "p_0_ego")], na.rm = TRUE)
  poor_ego <- accuracy_data$k[ego_accuracy < median(ego_accuracy, na.rm = TRUE)]
  cat("  IDs:", paste(poor_ego, collapse = ", "), "\n")
  
  cat("Poor alter accuracy (P(1|1) + P(0|0) < median):\n")
  alter_accuracy <- rowMeans(accuracy_data[, c("p_1_alter", "p_0_alter")], na.rm = TRUE)
  poor_alter <- accuracy_data$k[alter_accuracy < median(alter_accuracy, na.rm = TRUE)]
  cat("  IDs:", paste(poor_alter, collapse = ", "), "\n\n")
  
  return(list(
    high_performers = accuracy_data$k[high_perf],
    low_performers = accuracy_data$k[low_perf],
    poor_ego = poor_ego,
    poor_alter = poor_alter
  ))
}

# Run detailed breakdown
friendship_breakdown <- performance_breakdown(friendship_individual, "Friendship")
advice_breakdown <- performance_breakdown(advice_individual, "Advice")

